generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  userId       String   @unique // For public display or custom user ID
  email        String   @unique
  fullName     String
  passwordHash String?  // Optional because Google Login users might not have a password
  googleId     String?  @unique
  provider     String   @default("local") // "local" or "google"
  walletBalance Float    @default(0)
  broker       String?  @default("Kotak Neo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  kotakApiKeys KotakApiKey?
  otps         Otp[]
  transactions Transaction[]
}

model KotakApiKey {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  consumerKey    String
  consumerSecret String
  mpin           String
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              Int      @id @default(autoincrement())
  userId          Int
  amount          Float
  type            String   // "DEPOSIT" or "WITHDRAWAL" or "TRADE_BUY" or "TRADE_SELL"
  status          String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  razorpayOrderId String?  // For deposits
  razorpayPaymentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
